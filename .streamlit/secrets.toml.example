# Copia este archivo como .streamlit/secrets.toml para desarrollo local,
# o pega el mismo contenido (con tus datos reales) en Streamlit Cloud:
# tu app -> ⋮ -> Settings -> Secrets.
#
# Usa la cadena de conexión de tu proyecto de Supabase:
# Project Settings -> Database -> Connection string -> URI (modo "Session pooler" recomendado).

[connections.db]
url = "postgresql://postgres:<PASSWORD>@<HOST>:5432/postgres"
